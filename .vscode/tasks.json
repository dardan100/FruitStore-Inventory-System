{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "cppbuild",
      "label": "Build FruitStore (C++17)",
      "command": "g++",
      "args": [
        "-fdiagnostics-color=always",
        "-std=c++17",
        "-g",
        "${workspaceFolder}/main.cpp",
        "-o",
        "${workspaceFolder}/fruitstore"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Compiling code using C++17 standard"
    }
  ]
}
